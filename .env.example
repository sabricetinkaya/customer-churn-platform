# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=customer-churn-platform

# Consumer Groups
PREDICTION_CONSUMER_GROUP=prediction-service
PERSISTENCE_CONSUMER_GROUP=persistence-service

# Topics
CUSTOMER_TOPIC=customer.events
PREDICTION_TOPIC=prediction.events
RISK_TOPIC=risk.events

# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=churn_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password